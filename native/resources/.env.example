# Blender MCP — Environment Configuration
# Copy this file to %LOCALAPPDATA%\ai.fleet.blender-mcp\.env and edit.
# The server reads these at startup. Restart after changing.

# --- Paths ---
# Path to Blender executable (auto-detected if not set)
# BLENDER_PATH=C:\Program Files\Blender Foundation\Blender 4.2\blender.exe

# --- MCP Transport ---
# Transport mode: stdio (Claude Desktop), http (webapp/Tauri)
# MCP_TRANSPORT=http
# HTTP port when transport is http
MCP_PORT=10849
# Bind address
MCP_HOST=127.0.0.1

# --- Ollama (optional — for local LLM generation) ---
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- Tauri (set automatically by backend.rs) ---
# BLENDER_TAURI=1
