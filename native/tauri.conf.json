{
  "productName": "Blender MCP",
  "version": "0.1.0",
  "identifier": "ai.fleet.blender-mcp",
  "build": {
    "frontendDist": "../webapp/frontend/dist",
    "devUrl": "http://localhost:10848",
    "beforeDevCommand": "npm --prefix ../webapp/frontend run dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Blender MCP",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:10849 ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/blender-mcp-backend.exe",
      "resources/.env.example"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "process": {
      "all": true
    }
  }
}
